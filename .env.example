# ==============================================
# SSR Group Backend — Environment Configuration
# ==============================================

# --- App Settings ---
APP_NAME="SSR Group Backend"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# --- Database ---
# SQLite (default for dev). For production, use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ssrgroup
DATABASE_URL=sqlite+aiosqlite:///./ssr_group.db

# --- CORS ---
# Comma-separated allowed origins
CORS_ORIGINS=https://ssrgroupcivil.in,http://localhost:3000,http://localhost:8000

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SSR Group
SMTP_FROM_EMAIL=info@ssrgroupcivil.in

# --- Notification ---
# Email where all form submissions are sent
ADMIN_EMAIL=info@ssrgroupcivil.in

# --- WhatsApp (optional) ---
WHATSAPP_PHONE=918796138550

# --- HubSpot CRM (optional) ---
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_LIFECYCLE_STAGE=lead
HUBSPOT_LEAD_STATUS=NEW
# Optional custom HubSpot contact property names for lead metadata:
HUBSPOT_FORM_TYPE_PROPERTY=
HUBSPOT_DETAILS_PROPERTY=
